{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "next-env.d.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "src/test/**/*.ts",
    "src/test/**/*.tsx",
    "src/__tests__/**/*.ts",
    "src/__tests__/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
